{
  "name": "towteam",
  "version": "1.0.0",
  "description": "Self-hostable aircraft tow planning, tracking, and history app.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite --host 0.0.0.0",
    "start": "node server/index.js",
    "build": "vite build",
    "lint": "eslint .",
    "test": "node --test --test-concurrency=1 server/tests/*.test.js",
    "db:migrate": "node server/db/migrate.js",
    "db:seed": "node seed/seed.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "^11.8.1",
    "concurrently": "^10.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "lucide-react": "^0.468.0",
    "morgan": "^1.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "globals": "^17.7.0",
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
